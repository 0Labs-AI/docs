{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "0Labs Detections",
  "description": "Connect your cloud read-only and your IaC repo, and the agent triages findings and opens real fix PRs.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        { "anchor": "Home", "icon": "house", "href": "/" },
        { "anchor": "App", "icon": "layout-dashboard", "href": "https://app.0labs.ai" }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Connect",
        "icon": "plug",
        "expanded": true,
        "pages": [
          "connect-gcp",
          "connect-github"
        ]
      },
      {
        "group": "Reference",
        "icon": "shield-check",
        "expanded": true,
        "pages": [
          "permissions",
          "security",
          "troubleshooting"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://app.0labs.ai"
    }
  },
  "footer": {
    "links": [
      {
        "header": "0Labs",
        "items": [
          { "label": "App", "href": "https://app.0labs.ai" },
          { "label": "API", "href": "https://api.0labs.ai" }
        ]
      }
    ]
  }
}
