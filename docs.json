{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Agent0",
  "description": "Connect your cloud read-only and your IaC repo, and the agent triages findings and opens real fix PRs.",
  "colors": {
    "primary": "#14161C",
    "light": "#F4F0E1",
    "dark": "#14161C"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "assistant",
      "mcp",
      "add-mcp"
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "App",
          "icon": "layout-dashboard",
          "href": "https://app.0labs.ai"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Connect",
        "icon": "plug",
        "expanded": true,
        "pages": [
          "connect-gcp",
          "connect-github"
        ]
      },
      {
        "group": "Reference",
        "icon": "shield-check",
        "expanded": true,
        "pages": [
          "permissions",
          "security",
          "troubleshooting"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://app.0labs.ai"
    }
  },
  "footer": {
    "links": [
      {
        "header": "0Labs",
        "items": [
          {
            "label": "App",
            "href": "https://app.0labs.ai"
          },
          {
            "label": "API",
            "href": "https://api.0labs.ai"
          }
        ]
      }
    ]
  },
  "fonts": {
    "heading": {
      "family": "Manrope"
    },
    "body": {
      "family": "Inter"
    }
  }
}
